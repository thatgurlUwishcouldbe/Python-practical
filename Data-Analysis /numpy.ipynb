import numpy as np
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression
from sklearn.model_selection import train_test_split
from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score

import warnings
warnings.filterwarnings("ignore")

print("Libraries loaded successfully!")
np.random.seed(42)  # For reproducibility
n_samples = 1000

# Features
size = np.random.uniform(60, 350, n_samples)        # Size in square meters
bedrooms = np.random.randint(1, 6, n_samples)        # Number of bedrooms
age = np.random.uniform(0, 40, n_samples)            # Age of the house in years
distance = np.random.uniform(1, 50, n_samples)       # Distance to city center (km)
floor = np.random.randint(1, 20, n_samples)          # Floor number

price = (
    3.5 * size +
    50 * bedrooms +
    -8 * age +
    -12 * distance +
    5 * floor +
    200 +
    np.random.normal(0, 80, n_samples)  # Random noise
)
price = np.clip(price, 100, None)  # No negative prices

# Combine features into one matrix
X_housing = np.column_stack([size, bedrooms, age, distance, floor])
y_housing = price
feature_names = ["Size_sqm", "Bedrooms", "Age_years", "Distance_km", "Floor"]

print(f"Dataset shape: {X_housing.shape}")
print(f"Features: {feature_names}")
print(f"\nFirst 5 samples:")
print(f"{'Size':>8} {'Bed':>5} {'Age':>5} {'Dist':>6} {'Floor':>6} {'Price':>8}")
for i in range(5):
    print(f"{size[i]:>8.1f} {bedrooms[i]:>5} {age[i]:>5.1f} {distance[i]:>6.1f} {floor[i]:>6} {price[i]:>8.1f}")

X_train, X_test, y_train, y_test = train_test_split(X_housing, y_housing, test_size=0.2, random_state=42)

model = LinearRegression()

model.fit(X_housing, y_housing)

y_pred = model.predict(X_housing)

new_house = [[120, 3, 10, 15, 5]]
y_pred = model.predict(new_house)
print(y_pred)


plt.show()
